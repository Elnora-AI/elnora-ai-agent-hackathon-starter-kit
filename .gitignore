# ============================================================
# Environment & Secrets — NEVER commit these
# ============================================================
.env
.env.*
!.env.template
!.env.example
*.env

# Credential and secret files (any name/path)
**/credentials*.json
**/secrets*.json
**/auth*.json
**/*token*.json
**/*secret*.json
**/api-key*
**/apikey*

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
id_rsa*
id_ed25519*
id_ecdsa*

# SSH
.ssh/

# Cloud provider credentials
.aws/
aws-credentials*
gcp-*.json
*-keyfile.json
service-account*.json
.azure/
azure-*.json

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.*
.terraform/

# ============================================================
# Claude Code — local settings are per-user
# ============================================================
.claude/settings.local.json
.claude/knowledge-base.local.md
# Ephemeral lock files written by the harness (e.g. scheduled_tasks.lock)
.claude/*.lock

# Setup-time integrity marker. install.sh / install.ps1 write this on
# fresh extract; setup-mac.sh / setup-windows.ps1 verify the SHA against
# INSTALL_FOR_AGENTS.md before handing off to claude. It's scaffolding,
# not user content — keep it out of customers' initial commit.
.elnora-ai-agent-hackathon-starter-kit-marker

# Phase 2 collision-recovery resume marker. INSTALL_FOR_AGENTS.md step
# 6c.2 writes this when a GitHub repo-name collision forces a folder
# rename; the next session's step 0 reads it and jumps to step 6c.5.
# Lives on disk only across the close-rename-reopen handoff — must never
# enter git history (the user's first commit happens AFTER the rename, in
# step 6c.4's `git add .`). Step 0.6 deletes it locally once consumed.
.elnora-handoff-resume.json

# One-shot Phase 1 -> Phase 2 handoff sentinel. setup-mac.sh / setup-windows.ps1
# write the literal handoff prompt into this file, then open VS Code; the
# .vscode/run-handoff.{sh,ps1} helper reads it once and deletes it. Pure
# runtime state — never committed.
.vscode/.handoff-pending

# Runtime scratch folder — regenerable state, logs, downloaded artifacts
# Keep the folder (README + .gitkeep) but ignore everything else inside
cache/*
!cache/README.md
!cache/.gitkeep

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
._*

# ============================================================
# Editor / IDE files
# ============================================================
.vscode/settings.json
.vscode/launch.json
# Per-user VS Code workspace file generated by setup-mac.sh / setup-windows.ps1
# (named after the user's workspace folder). Local convenience, not shared.
*.code-workspace
.idea/
*.swp
*.swo
*~

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.Python
*.egg-info/
dist/
build/

# ============================================================
# .NET / C#
# ============================================================
bin/
obj/
*.user
*.suo

# ============================================================
# Build outputs & logs
# ============================================================
*.log
logs/
tmp/
temp/
test-logs/
